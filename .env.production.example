# ============================================
# 深象 OPCS - 生产环境变量配置模板
# 复制为 .env.production 并填写实际值
# ============================================

# --- 应用基础 ---
NODE_ENV=production
PORT=3000
APP_URL=http://112.124.25.136

# --- 数据库（Docker MySQL 容器） ---
# 由 docker-compose.yml 中的 environment 覆盖，此处可留空
DATABASE_URL=mysql://opcs_admin:OpcsDB2026vip!@mysql:3306/opcs_production

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- 认证 ---
JWT_SECRET=opcs-jwt-secret-2026-shenxiang-tech-random-string-42chars

# --- Docker MySQL 密码 ---
MYSQL_ROOT_PASSWORD=OpcsMySQL2026!
MYSQL_PASSWORD=OpcsDB2026vip!

# --- 阿里云通义千问（百炼平台） ---
ALIYUN_DASHSCOPE_API_KEY=sk-your-dashscope-api-key
ALIYUN_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_DASHSCOPE_MODEL=qwen-max
ALIYUN_DASHSCOPE_VISION_MODEL=qwen-vl-max

# --- Manus OAuth（保留兼容，自托管时可留空） ---
VITE_APP_ID=opcs-admin
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=

# --- Manus Forge API（保留兼容，自托管时可留空） ---
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# --- 安全 ---
CORS_ORIGIN=http://112.124.25.136
