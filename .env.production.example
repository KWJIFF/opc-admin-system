# ============================================
# 深象 OPCS - 生产环境变量配置模板
# 复制为 .env.production 并填写实际值
# ============================================

# --- 应用基础 ---
NODE_ENV=production
PORT=3000
APP_URL=https://opcs.vip

# --- 数据库（阿里云 RDS MySQL） ---
# 格式: mysql://用户名:密码@RDS内网地址:3306/数据库名?ssl={"rejectUnauthorized":true}
DATABASE_URL=mysql://opcs_admin:YOUR_PASSWORD@rm-xxxxx.mysql.rds.aliyuncs.com:3306/opcs_production

# --- Redis（阿里云 Redis 或本地 Docker Redis） ---
REDIS_URL=redis://localhost:6379

# --- 认证 ---
JWT_SECRET=your-jwt-secret-at-least-32-chars-long-random-string

# --- 阿里云 OSS 对象存储 ---
ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_OSS_BUCKET=opcs-assets
ALIYUN_OSS_REGION=oss-cn-shanghai
ALIYUN_OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_CDN_DOMAIN=https://cdn.opcs.vip

# --- 阿里云通义千问（百炼平台） ---
ALIYUN_DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
ALIYUN_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_DASHSCOPE_MODEL=qwen-max
ALIYUN_DASHSCOPE_VISION_MODEL=qwen-vl-max
ALIYUN_DASHSCOPE_LONG_MODEL=qwen-long

# --- 阿里云短信服务（登录验证码） ---
ALIYUN_SMS_ACCESS_KEY_ID=your-sms-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-sms-access-key-secret
ALIYUN_SMS_SIGN_NAME=深象科技
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxxx

# --- 阿里云邮件推送 ---
ALIYUN_EMAIL_ACCESS_KEY_ID=your-email-access-key-id
ALIYUN_EMAIL_ACCESS_KEY_SECRET=your-email-access-key-secret
ALIYUN_EMAIL_ACCOUNT=noreply@mail.opcs.vip
ALIYUN_EMAIL_FROM_ALIAS=深象科技

# --- 阿里云 SLS 日志服务 ---
ALIYUN_SLS_ACCESS_KEY_ID=your-sls-access-key-id
ALIYUN_SLS_ACCESS_KEY_SECRET=your-sls-access-key-secret
ALIYUN_SLS_ENDPOINT=cn-shanghai.log.aliyuncs.com
ALIYUN_SLS_PROJECT=opcs-logs
ALIYUN_SLS_LOGSTORE=app-logs

# --- 阿里云 CDN ---
ALIYUN_CDN_DOMAIN=cdn.opcs.vip

# --- 安全 ---
CORS_ORIGIN=https://opcs.vip
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
